# Skifta — environment variables.
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.

# ── Database (Postgres) ──────────────────────────────────────────────
# Vercel Postgres / Neon / Supabase connection string.
DATABASE_URL="postgresql://user:password@host:5432/skifta?schema=public"

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Session signing secret (generate: `openssl rand -base64 32`)
AUTH_SECRET=""

# ── AI (Anthropic, Haiku-class) — spec §8 ────────────────────────────
ANTHROPIC_API_KEY=""

# ── Billing (Stripe) — spec §12 ──────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Price ids — created by `node scripts/stripe-setup.mjs`, not hand-typed.
STRIPE_PRICE_BAS_MONTHLY=""
STRIPE_PRICE_BAS_YEARLY=""
STRIPE_PRICE_FULL_MONTHLY=""
STRIPE_PRICE_FULL_YEARLY=""
# Authenticates Vercel Cron hitting /api/cron/billing (generate: `openssl rand -base64 32`).
CRON_SECRET=""

# ── WebAuthn (QR + Face ID clock-in) — spec §5 ───────────────────────
# RP_ID is the registrable domain (no scheme/port), e.g. "skifta.se" or "localhost".
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="Skifta"
WEBAUTHN_ORIGIN="http://localhost:3000"

# ── Messaging (invites + one-time codes) — spec §4, §5 ───────────────
# SMS via 46elks (https://46elks.se/account — API username/password under "API").
SMS_PROVIDER_USERNAME=""
SMS_PROVIDER_PASSWORD=""
# Email via Resend (https://resend.com/api-keys).
EMAIL_PROVIDER_API_KEY=""
# Must be on a domain verified in Resend (https://resend.com/domains), or use
# the sandbox sender "onboarding@resend.dev" for testing before that's set up.
EMAIL_FROM="no-reply@skifta.se"
